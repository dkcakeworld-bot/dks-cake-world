# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DK's Cake World — Backend Environment
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?appName=Cluster0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Admin Credentials (seeded once to MongoDB)
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=your_admin_password

# Frontend URL (CORS whitelist)
CLIENT_URL=http://localhost:3000

# Contact Info
PHONE=+91 0000 000 000
WHATSAPP=+91 0000 000 000
ADDRESS=Your City
EMAIL=your@email.com
